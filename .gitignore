# ====================================================
# WHITELIST STRATEGY: ignore everything by default
# Only explicitly allowed files can be committed
# ====================================================

# Block everything
*

# Allow only specific files/dirs
!.gitignore
!.env.example
!README.md
!SECURITY.md
!SKILL.md
!EXTERNAL_AGENT_PROTOCOL.md
!CHANGELOG.md
!package.json
!package-lock.json

# Allow scripts/ folder (but not secrets inside)
!scripts/
scripts/*
!scripts/*.js

# Allow skills/ folder
!skills/
!skills/polyclawster-agent/
skills/polyclawster-agent/*
!skills/polyclawster-agent/.gitignore
!skills/polyclawster-agent/SKILL.md
!skills/polyclawster-agent/README.md
!skills/polyclawster-agent/SECURITY.md
!skills/polyclawster-agent/CHANGELOG.md
!skills/polyclawster-agent/package.json
!skills/polyclawster-agent/package-lock.json
!skills/polyclawster-agent/_meta.json
!skills/polyclawster-agent/scripts/
skills/polyclawster-agent/scripts/*
!skills/polyclawster-agent/scripts/*.js
!skills/polyclawster-agent/.clawhub/
skills/polyclawster-agent/.clawhub/*
!skills/polyclawster-agent/.clawhub/origin.json

# Always block these even if matched above
node_modules/
*.env
*.env.*
*.key
*.pem
config.json
*config*.json
wallet.json
